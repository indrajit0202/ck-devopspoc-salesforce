@isTest
public with sharing class AutoGenerateResumeTriggerHandlerTest {
    @TestSetup
    static void makeData(){
        User adminUser = CommonTestHelper.createUserWithProfile('System Administrator', 'testuser@example.com', 'randuser');
        Database.insert(adminUser);
        Candidate__c newCandidateObj = CommonTestHelper.createCandidateWithoutContact('Test', 'Class', 'test@example.com');
        insert newCandidateObj;
        Job_Application__c newJobAppObj = CommonTestHelper.createJobApplication(newCandidateObj);
        newJobAppObj.Status__c = 'New';
        insert newJobAppObj;
    }

    /**
    * @description Test method for autoresume generation.
    * @author Indrajit Pal | 12-26-2024 
    **/
    @isTest
    static void autoGenerateResumeTest(){
        User testingUser = CommonTestHelper.findUserWithEmail('testuser@example.com');
        Candidate__c candidateObj = [SELECT Id
                                        FROM Candidate__c
                                        WHERE First_Name__c = 'Test'
                                        LIMIT 1];
        Job_Application__c jobApplicationObj = [SELECT Id,
                                                        Status__c
                                                    FROM Job_Application__c
                                                    WHERE Candidate__c =: candidateObj.Id];

        List<Attachment> resumeListBeforeTrigger = [SELECT Id
                                                        FROM Attachment
                                                        WHERE ParentId =: candidateObj.Id];
        System.runAs(testingUser){
            Test.startTest();
            jobApplicationObj.Status__c = 'Schedule Interviews';
            update jobApplicationObj;
            Test.stopTest();
        }

        List<Attachment> resumeListAfterTrigger = [SELECT Id
                                                        FROM Attachment
                                                        WHERE ParentId =: candidateObj.Id];
        System.assertEquals(true, resumeListBeforeTrigger.size()+1 == resumeListAfterTrigger.size(), 'Resume should be generated by the Trigger.');
    }

    /**
    * @description Test method for the exceptions in the trigger.
    * @author Indrajit Pal | 12-26-2024 
    **/
    @isTest
    static void autoGenerateResumeExceptionTest(){
        User testingUser = CommonTestHelper.findUserWithEmail('testuser@example.com');
        Candidate__c candidateObj = [SELECT Id
                                        FROM Candidate__c
                                        WHERE First_Name__c = 'Test'
                                        LIMIT 1];
        Job_Application__c jobApplicationObj = [SELECT Id,
                                                        Status__c
                                                    FROM Job_Application__c
                                                    WHERE Candidate__c =: candidateObj.Id];

        List<Attachment> resumeListBeforeTrigger = [SELECT Id
                                                        FROM Attachment
                                                        WHERE ParentId =: candidateObj.Id];
        System.runAs(testingUser){
            Test.startTest();
            jobApplicationObj.Status__c = 'Phone Screen';
            update jobApplicationObj;
            Test.stopTest();
        }

        List<Attachment> resumeListAfterTrigger = [SELECT Id
                                                        FROM Attachment
                                                        WHERE ParentId =: candidateObj.Id];
        System.assertEquals(true, resumeListBeforeTrigger.size() == resumeListAfterTrigger.size(), 'There should be no resume generated from the trigger.');  
    }
}